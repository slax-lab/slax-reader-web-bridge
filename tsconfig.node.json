  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": ".tsbuild/node",
    "types": ["node"]
  },
  "include": ["rollup.config.ts", "rollup-env.d.ts"]
}
